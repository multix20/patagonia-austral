# =============================================================================
# Variables de entorno — Docker Compose de PRODUCCIÓN
# PWA Turismo Cochrane · Licitación ID 3797-37-LE26
# -----------------------------------------------------------------------------
# 1) Copia este archivo a .env  (en la misma carpeta app/)
#        cp .env.prod.example .env         (PowerShell: Copy-Item .env.prod.example .env)
# 2) Completa/ajusta los valores marcados con «CAMBIAR».
# 3) NO subas .env al repositorio (ya está en .gitignore).
# =============================================================================

# --- Dominio y SSL (Caddy) ---------------------------------------------------
# Dominio público real  -> HTTPS automático (Let's Encrypt).
#   SITE_ADDRESS=turismo.municochrane.cl
# Pruebas en tu PC (certificado local autofirmado de Caddy):
#   SITE_ADDRESS=localhost
# Pruebas sin TLS (solo http://localhost):
#   SITE_ADDRESS=http://localhost
SITE_ADDRESS=localhost
ACME_EMAIL=admin@municochrane.cl   # CAMBIAR: correo para avisos de certificados

# --- Aplicación Laravel ------------------------------------------------------
APP_NAME="Cochrane Turismo"
APP_ENV=production
APP_DEBUG=false
# URL pública del backend. En un solo dominio con Caddy = el mismo SITE_ADDRESS.
#   Local:  https://localhost   (o http://localhost si usas SITE_ADDRESS sin TLS)
#   Prod:   https://turismo.municochrane.cl
APP_URL=https://localhost
APP_TIMEZONE=America/Santiago
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
LOG_CHANNEL=stderr
# Genera una con:  php artisan key:generate --show    (o docker compose run --rm app php artisan key:generate --show)
APP_KEY=base64:O+1DNk4TIHTUKcVutvdgZ+Gt5okYC9EXbD1iVz+e3Nw=   # CAMBIAR en producción real

# --- Base de datos PostgreSQL ------------------------------------------------
DB_CONNECTION=pgsql
DB_DATABASE=cochrane_turismo
DB_USERNAME=cochrane
DB_PASSWORD=cambia_esta_clave_segura   # CAMBIAR: clave fuerte en producción
# DB_HOST y DB_PORT los fija el compose (db:5432). No hace falta definirlos aquí.

# --- Sesión / caché / colas (usan la BD) -------------------------------------
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- CORS: origen permitido para la PWA --------------------------------------
# Con un solo dominio (Caddy sirve PWA + API), es el mismo SITE_ADDRESS.
FRONTEND_URL=https://localhost

# --- Web Push (VAPID) --------------------------------------------------------
# Mismo par que en local/Render para no invalidar las suscripciones existentes.
# La pública también se hornea en el build del frontend (VITE_VAPID_PUBLIC_KEY).
VAPID_SUBJECT=mailto:turismo@municochrane.cl
VAPID_PUBLIC_KEY=BI_S5cKlSTNgTD-9Ic1CX4LI8v0zfWZeZ3Jcdl_Q8EmmK29ijPKPgKjllfjc0qAgClM2S7-5IoMsMAVXuFMsYM8
VAPID_PRIVATE_KEY=2iJlhvJeNf1SNPg2eSZ-YuGjBfDTi33E5Jvklx9a_Cs
